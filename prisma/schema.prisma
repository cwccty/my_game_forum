generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  OFFLINE
}

enum CategoryType {
  NEWS
  RESOURCE
  FORUM
}

enum ReportStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum AuditAction {
  SUBMIT
  APPROVE
  REJECT
  OFFLINE
  FEATURE
}

enum CommentTargetType {
  NEWS
  RESOURCE
  FORUM
}

enum FavoriteTargetType {
  NEWS
  RESOURCE
}

enum ReportTargetType {
  NEWS
  RESOURCE
  FORUM
  COMMENT
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  nickname        String
  avatar          String?
  role            UserRole    @default(USER)
  status          UserStatus  @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  newsPosts       NewsPost[]
  resourcePosts   ResourcePost[]
  forumPosts      ForumPost[]
  comments        Comment[]
  favorites       Favorite[]
  reports         Report[]
  auditLogs       AuditLog[]  @relation("AuditReviewer")
  accounts        Account[]
  sessions        Session[]
}

model Category {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  type          CategoryType
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  newsPosts     NewsPost[]
  resourcePosts ResourcePost[]
  forumPosts    ForumPost[]
}

model Tag {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  createdAt     DateTime          @default(now())
  newsPosts     NewsPostTag[]
  resourcePosts ResourcePostTag[]
  forumPosts    ForumPostTag[]
}

model NewsPost {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  summary       String
  content       String
  coverImage    String?
  status        ContentStatus @default(DRAFT)
  featured      Boolean       @default(false)
  viewCount     Int           @default(0)
  commentCount  Int           @default(0)
  favoriteCount Int           @default(0)
  publishedAt   DateTime?
  rejectReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authorId      String
  categoryId    String
  author        User          @relation(fields: [authorId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  tags          NewsPostTag[]
  comments      Comment[]
  favorites     Favorite[]
  reports       Report[]
  auditLogs     AuditLog[]
}

model ResourcePost {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  summary          String
  description      String
  coverImage       String?
  galleryImages    String[]
  externalUrl      String
  gameName         String
  gameVersion      String
  resourceVersion  String?
  status           ContentStatus @default(DRAFT)
  featured         Boolean       @default(false)
  viewCount        Int           @default(0)
  commentCount     Int           @default(0)
  favoriteCount    Int           @default(0)
  publishedAt      DateTime?
  rejectReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  authorId         String
  categoryId       String
  author           User          @relation(fields: [authorId], references: [id])
  category         Category      @relation(fields: [categoryId], references: [id])
  tags             ResourcePostTag[]
  comments         Comment[]
  favorites        Favorite[]
  reports          Report[]
  auditLogs        AuditLog[]
}

model ForumPost {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  summary       String
  content       String
  status        ContentStatus @default(DRAFT)
  featured      Boolean       @default(false)
  viewCount     Int           @default(0)
  commentCount  Int           @default(0)
  publishedAt   DateTime?
  rejectReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authorId      String
  categoryId    String
  author        User          @relation(fields: [authorId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  tags          ForumPostTag[]
  comments      Comment[]
  reports       Report[]
  auditLogs     AuditLog[]
}

model NewsPostTag {
  newsPostId String
  tagId      String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsPostId, tagId])
}

model ResourcePostTag {
  resourcePostId String
  tagId          String
  resourcePost   ResourcePost @relation(fields: [resourcePostId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourcePostId, tagId])
}

model ForumPostTag {
  forumPostId String
  tagId       String
  forumPost   ForumPost @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([forumPostId, tagId])
}

model Comment {
  id          String            @id @default(cuid())
  content     String
  targetType  CommentTargetType
  newsPostId  String?
  resourcePostId String?
  forumPostId String?
  authorId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  author      User              @relation(fields: [authorId], references: [id])
  newsPost    NewsPost?         @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  resourcePost ResourcePost?    @relation(fields: [resourcePostId], references: [id], onDelete: Cascade)
  forumPost   ForumPost?        @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
  reports     Report[]
}

model Favorite {
  id             String              @id @default(cuid())
  targetType     FavoriteTargetType
  userId         String
  newsPostId     String?
  resourcePostId String?
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsPost       NewsPost?           @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  resourcePost   ResourcePost?       @relation(fields: [resourcePostId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, newsPostId, resourcePostId])
}

model Report {
  id             String           @id @default(cuid())
  reason         String
  targetType     ReportTargetType
  status         ReportStatus     @default(OPEN)
  userId         String
  newsPostId     String?
  resourcePostId String?
  forumPostId    String?
  commentId      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsPost       NewsPost?        @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  resourcePost   ResourcePost?    @relation(fields: [resourcePostId], references: [id], onDelete: Cascade)
  forumPost      ForumPost?       @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
  comment        Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String        @id @default(cuid())
  action         AuditAction
  note           String?
  createdAt      DateTime      @default(now())
  reviewerId     String?
  newsPostId     String?
  resourcePostId String?
  forumPostId    String?
  reviewer       User?         @relation("AuditReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  newsPost       NewsPost?     @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  resourcePost   ResourcePost? @relation(fields: [resourcePostId], references: [id], onDelete: Cascade)
  forumPost      ForumPost?    @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
